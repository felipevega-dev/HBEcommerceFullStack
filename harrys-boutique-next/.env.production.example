# Production Environment Variables
# Copy these values into your hosting provider. Do not commit real secrets.

# Database
# Recommended target: Supabase Postgres + Vercel app hosting.
# Runtime URL: Supabase transaction pooler.
# Migration URL: Supabase direct port 5432 URL, used by Prisma through DIRECT_URL.
DATABASE_URL="postgresql://postgres.PROJECT_REF:PASSWORD@aws-0-region.pooler.supabase.com:6543/postgres?pgbouncer=true&connection_limit=1"
DIRECT_URL="postgresql://postgres:PASSWORD@db.PROJECT_REF.supabase.co:5432/postgres"

# NextAuth
# Generate with: openssl rand -base64 32
NEXTAUTH_SECRET="CHANGE-THIS-TO-A-SECURE-RANDOM-STRING-MIN-32-CHARS"
NEXTAUTH_URL="https://your-production-domain.com"

# Vercel Blob Storage
# Get from Vercel Dashboard -> Storage -> Create Blob Store.
BLOB_READ_WRITE_TOKEN="vercel_blob_rw_XXXXXXXXXXXXXXXXXXXXXXXX"

# MercadoPago production credentials
# Use production credentials, not test credentials.
MERCADOPAGO_ACCESS_TOKEN="APP_USR-PRODUCTION-ACCESS-TOKEN"
NEXT_PUBLIC_MERCADOPAGO_PUBLIC_KEY="APP_USR-PRODUCTION-PUBLIC-KEY"
MERCADOPAGO_WEBHOOK_SECRET="your-webhook-secret"

# Resend transactional emails
RESEND_API_KEY="re_XXXXXXXXXXXXXXXXXXXXXXXX"
RESEND_FROM_EMAIL="noreply@your-verified-domain.com"

# Rate limiting
UPSTASH_REDIS_REST_URL="https://your-instance.upstash.io"
UPSTASH_REDIS_REST_TOKEN="your-upstash-token"

# Instagram Graph API
INSTAGRAM_USER_ID="1784xxxxxxxxxxxx"
INSTAGRAM_ACCESS_TOKEN="EAAGxxxxxxxx"
INSTAGRAM_GRAPH_API_VERSION="v22.0"

# App configuration
NEXT_PUBLIC_FRONTEND_URL="https://your-production-domain.com"
ORDER_STOCK_RESERVATION_MINUTES="60"

# Supabase browser client
# These public keys are safe to expose. Never expose service_role keys.
NEXT_PUBLIC_SUPABASE_URL="https://your-project-ref.supabase.co"
NEXT_PUBLIC_SUPABASE_PUBLISHABLE_KEY="sb_publishable_your-key"

# Optional monitoring and analytics
NEXT_PUBLIC_SENTRY_DSN="https://xxx@xxx.ingest.sentry.io/xxx"
SENTRY_ORG="your-sentry-org"
SENTRY_PROJECT="your-sentry-project"
NEXT_PUBLIC_GA_ID="G-XXXXXXXXXX"

# Security
NODE_ENV="production"
NEXT_TELEMETRY_DISABLED="1"
