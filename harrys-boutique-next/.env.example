# ─── Database ─────────────────────────────────────────────────────────────────
# PostgreSQL connection string (Railway, Supabase, Neon, etc.)
DATABASE_URL="postgresql://user:password@host:5432/harrys_boutique"

# ─── NextAuth ─────────────────────────────────────────────────────────────────
# Generate with: openssl rand -base64 32
NEXTAUTH_SECRET="your-secret-here-min-32-chars"
# Full URL of your app (no trailing slash)
NEXTAUTH_URL="http://localhost:3000"

# ─── Vercel Blob Storage ──────────────────────────────────────────────────────
# Get from Vercel Dashboard → Storage → Create Blob Store → Copy token
# Free tier: 1GB storage, 100GB bandwidth/month
BLOB_READ_WRITE_TOKEN="vercel_blob_rw_your-token-here"

# ─── Cloudinary (DEPRECATED - migrated to Vercel Blob) ───────────────────────
# CLOUDINARY_NAME="your-cloud-name"
# CLOUDINARY_API_KEY="your-api-key"
# CLOUDINARY_SECRET_KEY="your-api-secret"

# ─── MercadoPago ──────────────────────────────────────────────────────────────
MERCADOPAGO_ACCESS_TOKEN="APP_USR-your-access-token"
NEXT_PUBLIC_MERCADOPAGO_PUBLIC_KEY="APP_USR-your-public-key"
# Get from MP dashboard → Webhooks → Secret key
MERCADOPAGO_WEBHOOK_SECRET="your-webhook-secret"

# ─── Resend (transactional emails) ────────────────────────────────────────────
RESEND_API_KEY="re_your-api-key"
# Must be a verified sender domain in Resend
RESEND_FROM_EMAIL="noreply@harrys-boutique.com"

# ─── App ──────────────────────────────────────────────────────────────────────
NEXT_PUBLIC_FRONTEND_URL="http://localhost:3000"

# ─── Migration only (not needed in production) ────────────────────────────────
# Only required when running: npm run migrate:mongo
MONGO_URI="mongodb+srv://user:password@cluster.mongodb.net"
