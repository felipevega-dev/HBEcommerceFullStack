# ─── Database ─────────────────────────────────────────────────────────────────
# Local development uses a dedicated Supabase development project or branch.
# Never point local development at the production database.
DATABASE_URL="postgresql://postgres.your-project-ref:[PASSWORD]@aws-0-your-region.pooler.supabase.com:6543/postgres?pgbouncer=true"

# Supabase Session Pooler URL for Prisma migrations and administrative commands.
# Use the direct URL only when it is reachable from your network (it can require IPv6).
DIRECT_URL="postgresql://postgres.your-project-ref:[PASSWORD]@aws-0-your-region.pooler.supabase.com:5432/postgres"

# ─── NextAuth ─────────────────────────────────────────────────────────────────
# Generate with: openssl rand -base64 32
NEXTAUTH_SECRET="your-secret-here-min-32-chars"
# Full URL of your app (no trailing slash)
NEXTAUTH_URL="http://localhost:3000"

# ─── Vercel Blob Storage ──────────────────────────────────────────────────────
# Get from Vercel Dashboard → Storage → Create Blob Store → Copy token
# Free tier: 1GB storage, 100GB bandwidth/month
BLOB_READ_WRITE_TOKEN="vercel_blob_rw_your-token-here"

# ─── Cloudinary (DEPRECATED - migrated to Vercel Blob) ───────────────────────
# CLOUDINARY_NAME="your-cloud-name"
# CLOUDINARY_API_KEY="your-api-key"
# CLOUDINARY_SECRET_KEY="your-api-secret"

# ─── MercadoPago ──────────────────────────────────────────────────────────────
MERCADOPAGO_ACCESS_TOKEN="APP_USR-your-access-token"
NEXT_PUBLIC_MERCADOPAGO_PUBLIC_KEY="APP_USR-your-public-key"
# Get from MP dashboard → Webhooks → Secret key
MERCADOPAGO_WEBHOOK_SECRET="your-webhook-secret"

# ─── Resend (transactional emails) ────────────────────────────────────────────
RESEND_API_KEY="re_your-api-key"
# Must be a verified sender domain in Resend
RESEND_FROM_EMAIL="noreply@harrys-boutique.com"

# ─── Rate Limiting (optional locally, recommended in production) ──────────────
UPSTASH_REDIS_REST_URL=""
UPSTASH_REDIS_REST_TOKEN=""

# ─── Instagram Graph API (automation) ─────────────────────────────────────────
# Business/Creator account required and linked in Meta
INSTAGRAM_USER_ID="1784xxxxxxxxxxxx"
INSTAGRAM_ACCESS_TOKEN="EAAGxxxxxxxx"
# Optional override
INSTAGRAM_GRAPH_API_VERSION="v22.0"

# ─── App ──────────────────────────────────────────────────────────────────────
NEXT_PUBLIC_FRONTEND_URL="http://localhost:3000"
ORDER_STOCK_RESERVATION_MINUTES="60"

# ─── Supabase Client (public keys) ────────────────────────────────────────────
NEXT_PUBLIC_SUPABASE_URL="https://your-project-ref.supabase.co"
NEXT_PUBLIC_SUPABASE_PUBLISHABLE_KEY="sb_publishable_your-key"
