# Database (Railway PostgreSQL)
DATABASE_URL="postgresql://user:password@host:5432/harrys_boutique"

# NextAuth
NEXTAUTH_SECRET="your-secret-here-min-32-chars"
NEXTAUTH_URL="http://localhost:3000"

# Cloudinary
CLOUDINARY_NAME="your-cloud-name"
CLOUDINARY_API_KEY="your-api-key"
CLOUDINARY_SECRET_KEY="your-api-secret"

# MercadoPago
MERCADOPAGO_ACCESS_TOKEN="your-access-token"
NEXT_PUBLIC_MERCADOPAGO_PUBLIC_KEY="your-public-key"

# Resend (emails)
RESEND_API_KEY="re_your-api-key"
RESEND_FROM_EMAIL="noreply@harrys-boutique.com"

# App
NEXT_PUBLIC_FRONTEND_URL="http://localhost:3000"

# MongoDB (only needed for migration script)
MONGO_URI="mongodb+srv://user:password@cluster.mongodb.net"
