// This is your Prisma schema file
// Learn more: https://pris.ly/d/prisma-schema

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

// ─── Enums ────────────────────────────────────────────────────────────────────

enum Role {
  OWNER
  ADMIN
  MODERATOR
  USER
}

enum OrderStatus {
  PENDING
  PROCESSING
  SHIPPED
  DELIVERED
  CANCELLED
}

enum PaymentStatus {
  PENDING
  PAID
  FAILED
  REFUNDED
}

enum DiscountType {
  PERCENTAGE
  FIXED
}

enum InstagramPostStatus {
  DRAFT
  PENDING
  PROCESSING
  PUBLISHED
  FAILED
  SKIPPED
}

enum MercadoLibreListingStatus {
  ACTIVE
  PAUSED
  INACTIVE
}

// ─── User & Auth ──────────────────────────────────────────────────────────────

model User {
  id           String   @id @default(uuid())
  name         String
  email        String   @unique
  password     String
  role         Role     @default(USER)
  profileImage String?
  tags         String[] @default([])
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  addresses           Address[]
  cart                Cart?
  orders              Order[]
  reviews             Review[]
  wishlist            Wishlist[]
  auditLogs           AuditLog[]
  couponRedemptions   CouponRedemption[]
  passwordResetTokens PasswordResetToken[]

  @@map("users")
}

model PasswordResetToken {
  id        String    @id @default(uuid())
  userId    String
  tokenHash String    @unique
  expiresAt DateTime
  usedAt    DateTime?
  createdAt DateTime  @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([expiresAt])
  @@map("password_reset_tokens")
}

model Address {
  id         String  @id @default(uuid())
  userId     String
  firstname  String
  lastname   String
  phone      String
  street     String
  city       String
  region     String
  postalCode String
  country    String
  isDefault  Boolean @default(false)

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([userId, isDefault])
  @@map("addresses")
}

// ─── Catalog ──────────────────────────────────────────────────────────────────

model Category {
  id            String   @id @default(uuid())
  name          String   @unique
  slug          String?  @unique
  subcategories String[]
  homeImage     String?
  homeDescription String? @db.Text
  homeHref      String?
  active        Boolean  @default(true)
  homeVisible   Boolean  @default(false)
  homeOrder     Int      @default(0)
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  products          Product[]
  homeCategoryBlock HomeCategoryBlock?

  @@index([active, homeVisible, homeOrder])
  @@map("categories")
}

model Product {
  id             String   @id @default(uuid())
  slug           String   @unique @default("")
  sku            String?  @unique
  name           String
  description    String
  seoTitle       String?
  seoDescription String?
  mercadoLibreUrl String?
  mercadoLibreItemId String? @unique
  mercadoLibreStatus MercadoLibreListingStatus @default(INACTIVE)
  price          Decimal  @db.Decimal(10, 2)
  originalPrice  Decimal? @db.Decimal(10, 2)
  images         String[]
  categoryId     String
  subCategory    String
  colors         String[]
  sizes          Json
  bestSeller     Boolean  @default(false)
  active         Boolean  @default(true)
  stock          Int      @default(0)
  ratingAverage  Float    @default(0)
  ratingCount    Int      @default(0)
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  category       Category         @relation(fields: [categoryId], references: [id])
  reviews        Review[]
  orderItems     OrderItem[]
  wishlist       Wishlist[]
  heroSlides     HeroSlide[]
  cartItems      CartItem[]
  variants       ProductVariant[]
  instagramPosts InstagramPost[]
  homeSelections HomeProductSelection[]
  homeCategoryItems HomeCategoryProduct[]

  @@index([slug])
  @@index([categoryId, subCategory])
  @@index([bestSeller])
  @@index([createdAt(sort: Desc)])
  @@index([ratingAverage(sort: Desc)])
  @@index([mercadoLibreStatus])
  @@map("products")
}

model HomeProductSelection {
  id        String   @id @default(uuid())
  productId String
  section   String   @default("FEATURED")
  visible   Boolean  @default(true)
  order     Int      @default(0)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  product Product @relation(fields: [productId], references: [id], onDelete: Cascade)

  @@unique([productId, section])
  @@index([section, visible, order])
  @@map("home_product_selections")
}

model HomeCategoryBlock {
  id         String   @id @default(uuid())
  categoryId String   @unique
  mode       String   @default("AUTO")
  maxItems   Int      @default(4)
  visible    Boolean  @default(true)
  order      Int      @default(0)
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  category Category               @relation(fields: [categoryId], references: [id], onDelete: Cascade)
  items    HomeCategoryProduct[]

  @@index([visible, order])
  @@map("home_category_blocks")
}

model HomeCategoryProduct {
  id        String   @id @default(uuid())
  blockId   String
  productId String
  visible   Boolean  @default(true)
  order     Int      @default(0)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  block   HomeCategoryBlock @relation(fields: [blockId], references: [id], onDelete: Cascade)
  product Product            @relation(fields: [productId], references: [id], onDelete: Cascade)

  @@unique([blockId, productId])
  @@index([blockId, visible, order])
  @@map("home_category_products")
}

model ProductVariant {
  id        String   @id @default(uuid())
  productId String
  size      String
  color     String   @default("")
  stock     Int      @default(0)
  sku       String?  @unique
  active    Boolean  @default(true)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  product    Product     @relation(fields: [productId], references: [id], onDelete: Cascade)
  cartItems  CartItem[]
  orderItems OrderItem[]

  @@unique([productId, size, color])
  @@index([productId, active])
  @@index([stock])
  @@map("product_variants")
}

// ─── Cart ─────────────────────────────────────────────────────────────────────

model Cart {
  id        String     @id @default(uuid())
  userId    String     @unique
  updatedAt DateTime   @updatedAt
  items     CartItem[]

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("carts")
}

model CartItem {
  id        String  @id @default(uuid())
  cartId    String
  productId String
  variantId String?
  quantity  Int
  size      String
  color     String  @default("")

  cart    Cart            @relation(fields: [cartId], references: [id], onDelete: Cascade)
  product Product         @relation(fields: [productId], references: [id], onDelete: Cascade)
  variant ProductVariant? @relation(fields: [variantId], references: [id], onDelete: SetNull)

  @@unique([cartId, productId, size, color])
  @@index([cartId])
  @@index([variantId])
  @@map("cart_items")
}

// ─── Orders ───────────────────────────────────────────────────────────────────

model Order {
  id              String      @id @default(uuid())
  userId          String
  amount          Decimal     @db.Decimal(10, 2)
  addressSnapshot Json
  status          OrderStatus @default(PENDING)
  paymentMethod   String
  payment         Boolean     @default(false)
  paymentStatus   PaymentStatus @default(PENDING)
  paidAt          DateTime?
  paymentProvider String?
  paymentProviderId String?   @unique
  stockReservedAt DateTime?
  stockReservationExpiresAt DateTime?
  stockReleasedAt DateTime?
  couponCode      String?
  discountAmount  Decimal?    @db.Decimal(10, 2)
  internalNotes   String      @default("") @db.Text
  courier         String?
  trackingNumber  String?
  shippedAt       DateTime?
  deliveredAt     DateTime?
  cancelReason    String?
  refundReason    String?
  createdAt       DateTime    @default(now())
  updatedAt       DateTime    @updatedAt

  user              User                 @relation(fields: [userId], references: [id])
  items             OrderItem[]
  statusHistory     OrderStatusHistory[]
  couponRedemptions CouponRedemption[]

  @@index([userId, createdAt(sort: Desc)])
  @@index([status])
  @@index([status, createdAt(sort: Desc)])
  @@index([payment, createdAt(sort: Desc)])
  @@index([paymentStatus, createdAt(sort: Desc)])
  @@index([stockReservationExpiresAt])
  @@map("orders")
}

model OrderItem {
  id        String  @id @default(uuid())
  orderId   String
  productId String?
  variantId String?
  name      String
  price     Decimal @db.Decimal(10, 2)
  quantity  Int
  size      String
  color     String  @default("")
  image     String  @default("")

  order   Order           @relation(fields: [orderId], references: [id], onDelete: Cascade)
  product Product?        @relation(fields: [productId], references: [id], onDelete: SetNull)
  variant ProductVariant? @relation(fields: [variantId], references: [id], onDelete: SetNull)

  @@index([variantId])
  @@index([productId])
  @@map("order_items")
}

model OrderStatusHistory {
  id             String      @id @default(uuid())
  orderId        String
  previousStatus OrderStatus?
  status         OrderStatus
  note           String?     @db.Text
  createdAt      DateTime    @default(now())

  order Order @relation(fields: [orderId], references: [id], onDelete: Cascade)

  @@index([orderId, createdAt(sort: Desc)])
  @@map("order_status_history")
}

// ─── Reviews ──────────────────────────────────────────────────────────────────

model Review {
  id        String   @id @default(uuid())
  userId    String
  productId String
  rating    Int
  comment   String   @db.VarChar(500)
  approved  Boolean  @default(false)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  user    User    @relation(fields: [userId], references: [id], onDelete: Cascade)
  product Product @relation(fields: [productId], references: [id], onDelete: Cascade)

  @@unique([userId, productId])
  @@index([productId, approved, createdAt(sort: Desc)])
  @@map("reviews")
}

// ─── Wishlist ─────────────────────────────────────────────────────────────────

model Wishlist {
  id        String   @id @default(uuid())
  userId    String
  productId String
  createdAt DateTime @default(now())

  user    User    @relation(fields: [userId], references: [id], onDelete: Cascade)
  product Product @relation(fields: [productId], references: [id], onDelete: Cascade)

  @@unique([userId, productId])
  @@index([userId, createdAt(sort: Desc)])
  @@map("wishlists")
}

// ─── Coupons ──────────────────────────────────────────────────────────────────

model Coupon {
  id             String       @id @default(uuid())
  code           String       @unique
  discountType   DiscountType
  discountValue  Decimal      @db.Decimal(10, 2)
  minOrderAmount Decimal?     @db.Decimal(10, 2)
  maxUses        Int?
  usedCount      Int          @default(0)
  expiresAt      DateTime?
  active         Boolean      @default(true)
  createdAt      DateTime     @default(now())

  redemptions CouponRedemption[]

  @@index([active, expiresAt])
  @@map("coupons")
}

model CouponRedemption {
  id            String    @id @default(uuid())
  couponId      String
  userId        String
  orderId       String    @unique
  amount        Decimal   @default(0) @db.Decimal(10, 2)
  createdAt     DateTime  @default(now())
  releasedAt    DateTime?
  releaseReason String?

  coupon Coupon @relation(fields: [couponId], references: [id], onDelete: Cascade)
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)
  order  Order  @relation(fields: [orderId], references: [id], onDelete: Cascade)

  @@index([couponId, createdAt(sort: Desc)])
  @@index([userId, createdAt(sort: Desc)])
  @@map("coupon_redemptions")
}

// ─── Audit Log ────────────────────────────────────────────────────────────────

model AuditLog {
  id         String   @id @default(uuid())
  userId     String
  action     String
  resource   String
  resourceId String?
  changes    Json?
  ip         String?
  userAgent  String?
  createdAt  DateTime @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, createdAt(sort: Desc)])
  @@index([resource, createdAt(sort: Desc)])
  @@map("audit_logs")
}

// ─── Testimonials ─────────────────────────────────────────────────────────────

model Testimonial {
  id        String   @id @default(uuid())
  name      String
  role      String   @default("")
  comment   String   @db.VarChar(500)
  rating    Int      @default(5)
  avatar    String?
  active    Boolean  @default(true)
  status    String   @default("PENDING") // PENDING, APPROVED, REJECTED
  order     Int      @default(0)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([active, order])
  @@map("testimonials")
}

// ─── Settings ─────────────────────────────────────────────────────────────────

model Settings {
  id          String   @id @default(uuid())
  key         String   @unique
  value       String
  description String?
  updatedAt   DateTime @updatedAt

  @@map("settings")
}

// ─── Hero Slides ──────────────────────────────────────────────────────────────

model HeroSlide {
  id        String   @id @default(uuid())
  title     String
  subtitle  String
  image     String
  productId String
  order     Int      @default(0)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  product Product @relation(fields: [productId], references: [id], onDelete: Cascade)

  @@index([order])
  @@map("hero_slides")
}

model InstagramAutomationSettings {
  id                    String   @id @default(uuid())
  enabled               Boolean  @default(false)
  timezone              String   @default("America/Santiago")
  dailyHour             Int      @default(10)
  dailyMinute           Int      @default(0)
  sourceType            String   @default("PRODUCTS")
  captionTemplate       String   @db.Text
  fallbackHashtags      String   @default("")
  maxDailyPosts         Int      @default(1)
  requireManualApproval Boolean  @default(true)
  createdAt             DateTime @default(now())
  updatedAt             DateTime @updatedAt

  @@map("instagram_automation_settings")
}

model InstagramPost {
  id                  String              @id @default(uuid())
  productId           String?
  status              InstagramPostStatus @default(DRAFT)
  sourceType          String              @default("PRODUCTS")
  imageUrl            String
  title               String
  sourceDescription   String?             @db.Text
  captionDraft        String?             @db.Text
  finalCaption        String?             @db.Text
  scheduledFor        DateTime?
  publishedAt         DateTime?
  selectedAt          DateTime?
  processedAt         DateTime?
  instagramCreationId String?
  instagramMediaId    String?
  retryCount          Int                 @default(0)
  lastError           String?             @db.Text
  instagramUrl        String?
  altText             String?
  homeCaption         String?             @db.Text
  likes               Int?
  homeVisible         Boolean             @default(false)
  homeOrder           Int                 @default(0)
  createdAt           DateTime            @default(now())
  updatedAt           DateTime            @updatedAt

  product  Product?               @relation(fields: [productId], references: [id], onDelete: SetNull)
  attempts InstagramPostAttempt[]

  @@index([status, scheduledFor])
  @@index([productId])
  @@index([createdAt(sort: Desc)])
  @@index([homeVisible, homeOrder])
  @@map("instagram_posts")
}

model InstagramPostAttempt {
  id              String   @id @default(uuid())
  instagramPostId String
  status          String
  message         String?  @db.Text
  requestPayload  Json?
  responsePayload Json?
  createdAt       DateTime @default(now())

  instagramPost InstagramPost @relation(fields: [instagramPostId], references: [id], onDelete: Cascade)

  @@index([instagramPostId, createdAt(sort: Desc)])
  @@map("instagram_post_attempts")
}
