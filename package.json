{
  "name": "hbecommercefullstack",
  "private": true,
  "version": "1.0.0",
  "workspaces": [
    "frontend",
    "admin",
    "backend"
  ],
  "engines": {
    "node": ">=20.19.0 || >=22.12.0"
  },
  "scripts": {
    "install:all": "npm install --workspaces",
    "dev": "npm run dev --workspace frontend",
    "dev:frontend": "npm run dev --workspace frontend",
    "dev:admin": "npm run dev --workspace admin",
    "dev:backend": "npm run dev --workspace backend",
    "build": "npm run build --workspace frontend && npm run build --workspace admin",
    "build:frontend": "npm run build --workspace frontend",
    "build:admin": "npm run build --workspace admin",
    "lint": "npm run lint --workspace frontend && npm run lint --workspace admin && npm run lint --workspace backend",
    "lint:frontend": "npm run lint --workspace frontend",
    "lint:admin": "npm run lint --workspace admin",
    "lint:backend": "npm run lint --workspace backend",
    "start:backend": "npm run start --workspace backend"
  }
}
