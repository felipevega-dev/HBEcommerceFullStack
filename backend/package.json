{
  "name": "backend",
  "version": "1.0.0",
  "description": "HB Ecommerce backend API",
  "main": "server.js",
  "type": "module",
  "engines": {
    "node": ">=20.19.0 || >=22.12.0"
  },
  "scripts": {
    "dev": "nodemon server.js",
    "start": "node server.js",
    "server": "nodemon server.js",
    "lint": "eslint . --ext .js --max-warnings=0",
    "test": "node --experimental-vm-modules node_modules/.bin/jest --runInBand",
    "migrate:up": "migrate-mongo up",
    "migrate:down": "migrate-mongo down",
    "migrate:status": "migrate-mongo status"
  },
  "author": "",
  "license": "ISC",
  "dependencies": {
    "bcrypt": "^5.1.1",
    "chalk": "^4.1.2",
    "cloudinary": "^2.5.1",
    "cors": "^2.8.5",
    "dotenv": "^16.4.5",
    "express": "^4.21.1",
    "express-mongo-sanitize": "^2.2.0",
    "express-rate-limit": "^8.3.2",
    "jsonwebtoken": "^9.0.2",
    "mercadopago": "^2.0.15",
    "mongoose": "^8.8.2",
    "multer": "^1.4.5-lts.1",
    "nodemon": "^3.1.7",
    "validator": "^13.12.0",
    "winston": "^3.19.0"
  },
  "devDependencies": {
    "@eslint/js": "^9.39.1",
    "@jest/globals": "^30.3.0",
    "eslint": "^9.39.1",
    "globals": "^16.4.0",
    "jest": "^30.3.0",
    "migrate-mongo": "^14.0.7"
  },
  "jest": {
    "transform": {},
    "extensionsToTreatAsEsm": [
      ".js"
    ],
    "testEnvironment": "node",
    "testMatch": [
      "**/tests/**/*.test.js"
    ]
  }
}
